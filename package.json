{
  "name": "@freibergergarcia/phone-a-friend",
  "version": "3.0.0",
  "description": "CLI relay that lets AI coding agents collaborate",
  "homepage": "https://github.com/freibergergarcia/phone-a-friend#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freibergergarcia/phone-a-friend.git"
  },
  "bugs": {
    "url": "https://github.com/freibergergarcia/phone-a-friend/issues"
  },
  "keywords": [
    "ai-agent",
    "anthropic",
    "claude-code",
    "cli",
    "codex",
    "command-line-tool",
    "developer-tools",
    "gemini",
    "generative-ai",
    "llm",
    "openai",
    "ollama",
    "typescript"
  ],
  "type": "module",
  "bin": {
    "phone-a-friend": "dist/index.js"
  },
  "scripts": {
    "build": "tsup && node scripts/sync-codex-plugin.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm --watch",
    "bump:patch": "node scripts/bump-version.mjs patch",
    "bump:minor": "node scripts/bump-version.mjs minor",
    "bump:major": "node scripts/bump-version.mjs major",
    "preuninstall": "node dist/index.js plugin uninstall --all 2>/dev/null || true; rm -rf \"${XDG_CONFIG_HOME:-$HOME/.config}/phone-a-friend\" 2>/dev/null || true"
  },
  "files": [
    "dist/",
    ".claude-plugin/",
    ".codex-plugin/",
    ".agents/",
    "plugins/",
    "skills/",
    "commands/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "license": "Apache-2.0",
  "author": "Bruno Freiberger",
  "contributors": [
    "ovidiul"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "ink": "^7.0.5",
    "ora": "^9.3.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.16",
    "ink-testing-library": "^4.0.0",
    "js-yaml": "^4.1.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
