#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if ! command -v node >/dev/null 2>&1; then
  echo "Error: Node.js >= 22.13 is required. Install: https://nodejs.org/" >&2
  exit 1
fi

NODE_MAJOR=$(node -e "console.log(process.versions.node.split('.')[0])")
NODE_MINOR=$(node -e "console.log(process.versions.node.split('.')[1])")
if [ "$NODE_MAJOR" -lt 22 ] 2>/dev/null || { [ "$NODE_MAJOR" -eq 22 ] && [ "$NODE_MINOR" -lt 13 ] 2>/dev/null; }; then
  echo "Error: Node.js >= 22.13 required (found v$(node -v)). Update: https://nodejs.org/" >&2
  exit 1
fi

if [ ! -f "${SCRIPT_DIR}/dist/index.js" ]; then
  echo "Error: dist/index.js not found. Run 'npm run build' in ${SCRIPT_DIR}" >&2
  exit 1
fi

exec node "${SCRIPT_DIR}/dist/index.js" "$@"
